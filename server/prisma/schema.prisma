// 花语嫁接师 — Phase 1.5 Schema
// ================================
// Phase 1.5 新增：
// - Flower.location, sellPrice, factorScore, growthImageSeed/Url
// - Flower.isFoundation, stabilityProgress, stabilityTargetId, foundationName
// - Seed.growthImages, isFoundationSeed, seedType, parentFlowerId, totalSold
// - User.title
// - 新 TransactionLog type: REVENUE_SHARE, HARVEST_SELL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// 用户
// ========================
model User {
  id        String   @id @default(uuid())
  name      String
  email     String?
  unionId   String?
  gold      Int      @default(500)
  diamond   Int      @default(0)
  xp        Int      @default(0)
  level     Int      @default(1)
  title     String?  // 称号（如"玫瑰育种家"）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  flowers      Flower[]
  gardenSlots  GardenSlot[]
  fusionLogs   FusionLog[]
  transactions TransactionLog[]
}

// ========================
// 花
// ========================
model Flower {
  id          String    @id @default(uuid())
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id])
  name        String?
  parentAId   String?
  parentBId   String?
  rarity      String    // N / R / SR / SSR / UR
  atoms       Json      // [{ id, category, level, score, prompt_chinese, prompt_en }]
  factorScore Int       @default(0) // 因子总积分
  stage       String    @default("SEED")
  progress    Float     @default(0)
  imageUrl    String?
  isShopSeed  Boolean   @default(false)

  // Phase 1.5: 仓库制
  location    String    @default("GARDEN") // GARDEN / WAREHOUSE
  sellPrice   Int?      // 仓库出售价（入库时预计算）

  // Phase 1.5: 性状稳定
  isFoundation       Boolean  @default(false)
  stabilityProgress  Int      @default(0)  // 0-10
  stabilityTargetId  String?  // 被指定为母株的那株花的 id（如果是嫁接结果）
  foundationName     String?

  // Phase 1.5: 生长期图片
  growthImageSeed    String?  // 指向 Seed 品种名（融合花取父本A的生长期图）
  growthImageUrl     String?  // BLOOMING 的 SD 专属图

  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  gardenSlot GardenSlot?

  @@index([ownerId])
  @@index([ownerId, stage])
  @@index([ownerId, location])
}

// ========================
// 花园槽位（每用户 6 个）
// ========================
model GardenSlot {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  position  Int      // 0~5
  flowerId  String?  @unique
  flower    Flower?  @relation(fields: [flowerId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, position])
  @@index([userId])
}

// ========================
// 种子（商店数据 + 背包）
// ========================
model Seed {
  id          String   @id @default(uuid())
  name        String   @unique
  description String   @default("")
  emoji       String   @default("🌱")
  priceGold   Int
  atomLibrary Json     // [{ atomId, guaranteed }]
  growthImages Json?   // { seed: "url", seedling: "url", growing: "url", mature: "url", blooming: "url" }
  growTime    Int      @default(0)
  isActive    Boolean  @default(true)

  // Phase 1.5: 奠基种商店
  isFoundationSeed   Boolean  @default(false)
  foundationFlowerId  String?
  sellerId            String?
  customPrice         Int?
  revenueShare        Float    @default(0.8)

  // Phase 1.5: 种子类型
  seedType       String   @default("SYSTEM") // SYSTEM / FUSION_DROP / FOUNDATION / INHERIT
  parentFlowerId  String?
  totalSold       Int      @default(0)

  createdAt DateTime @default(now())
}

// ========================
// 嫁接日志
// ========================
model FusionLog {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  parentAId      String?
  parentBId      String?
  soil           String?
  ritual         String?
  success        Boolean
  failType       String?
  resultRarity   String?
  resultAtoms    Json     @default("[]")
  resultFlowerId String?
  factorScore    Int      @default(0) // Phase 1.5: 融合结果因子积分
  isFirstTime    Boolean  @default(false)
  rewardGold     Int      @default(0)
  rewardXp       Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([userId, parentAId, parentBId, resultRarity])
}

// ========================
// 交易流水
// ========================
model TransactionLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // BUY / FUSION_REWARD / HARVEST_SELL / REVENUE_SHARE / SYSTEM / REFUND
  currency  String   @default("GOLD")
  amount    Int
  balance   Int
  reason    String?
  relatedId String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, type])
}
