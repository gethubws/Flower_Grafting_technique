// 花语嫁接师 — Phase 1 Schema
// ================================
// 设计原则：
// - Stage 统一大写（SEED/SEEDLING/GROWING/MATURE/BLOOMING/RECOVERING）
// - 亲本消耗：嫁接成功后删除亲本 Flower 记录，释放 GardenSlot
// - 基础花 vs 融合花：parentAId===null 且 isShopSeed===true 为基础花；parentAId!==null 为融合花
// - Phase 1 游客模式：email 可空，不校验唯一性
// - TransactionLog 记录所有金币/钻石变动

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// 用户
// ========================
model User {
  id        String   @id @default(uuid())
  name      String
  email     String?  // Phase 1 可空，游客模式
  unionId   String?  // Phase 1 预留，未来第三方登录
  gold      Int      @default(500)
  diamond   Int      @default(0)
  xp        Int      @default(0)
  level     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  flowers      Flower[]
  gardenSlots  GardenSlot[]
  fusionLogs   FusionLog[]
  transactions TransactionLog[]
}

// ========================
// 花
// ========================
model Flower {
  id         String    @id @default(uuid())
  ownerId    String
  owner      User      @relation(fields: [ownerId], references: [id])
  name       String?
  parentAId  String?
  parentBId  String?
  rarity     String    // N / R / SR / SSR / UR
  atoms      Json      // e.g. ["剑形叶","唇瓣卷曲"]
  stage      String    @default("SEED") // SEED/SEEDLING/GROWING/MATURE/BLOOMING/RECOVERING
  progress   Float     @default(0) // 0~100，按阈值自动切换 stage
  imageUrl   String?
  isShopSeed Boolean   @default(false) // true=基础花（源自商店种子）
  isStable   Boolean   @default(false) // 是否奠基种（Phase 5）
  consumedAt DateTime? // 嫁接成功后标记消耗时间（或直接删除记录）
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // 关联
  logsAsParentA FusionLog[] @relation("ParentA")
  logsAsParentB FusionLog[] @relation("ParentB")
  gardenSlot    GardenSlot?

  @@index([ownerId])
  @@index([ownerId, stage])
}

// ========================
// 花园槽位（每用户 6 个）
// ========================
model GardenSlot {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  position  Int      // 0~5，2行3列
  flowerId  String?  @unique // 一个花只能在一个槽位
  flower    Flower?  @relation(fields: [flowerId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, position])
  @@index([userId])
}

// ========================
// 种子（商店数据）
// ========================
model Seed {
  id          String   @id @default(uuid())
  name        String   @unique // 玫瑰/向日葵/百合/郁金香/蝴蝶兰
  description String   @default("")
  emoji       String   @default("🌱") // 前端展示用
  priceGold   Int      // 金币价格
  atomLibrary Json     // 可选原子池 e.g. ["红花","重瓣","香气1"]
  growTime    Int      @default(0) // Phase 3 自动生长时间（秒），Phase 1 手动推进故为 0
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// ========================
// 嫁接日志
// ========================
model FusionLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  parentAId    String?
  parentA      Flower?  @relation("ParentA", fields: [parentAId], references: [id], onDelete: SetNull)
  parentBId    String?
  parentB      Flower?  @relation("ParentB", fields: [parentBId], references: [id], onDelete: SetNull)
  soil         String?  // HUMUS / SANDY / CLAY / LOAM
  ritual       String?  // NONE / WHISTLE / SING / PRAY（Phase 1 预留）
  success      Boolean
  failType     String?  // NORMAL / GRAVE（仅失败时有值）
  resultRarity String?  // 成功时有值
  resultAtoms  Json     @default("[]")
  resultFlowerId String? // 成功后关联的 Flower ID
  isFirstTime  Boolean  @default(false) // 该组合+珍稀度首次触发
  rewardGold   Int      @default(0)
  rewardXp     Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([userId, parentAId, parentBId, resultRarity])
}

// ========================
// 交易流水
// ========================
model TransactionLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // BUY / FUSION_REWARD / SYSTEM / REFUND
  currency  String   @default("GOLD") // GOLD / DIAMOND
  amount    Int      // 正数=收入，负数=支出
  balance   Int      // 变动后余额
  reason    String?  // 描述
  relatedId String?  // 关联对象 ID（如 seedId / flowerId）
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, type])
}
